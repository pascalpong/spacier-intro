# ----------------------------------------------------------------------------
# Spacier site — environment variables
# Copy this file to `.env.local` and fill in real values. Never commit secrets.
# ----------------------------------------------------------------------------

# Public site URL, used for metadata / canonical / OG tags.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# The PIN that reveals the private work lives in src/lib/projects.ts (WORK_PIN).
# It's a client-side "soft" gate, so it isn't an env secret — edit it there.

# Where the contact form should send leads. The current build handles the form
# entirely on the client (no backend); wire one of these up when you add a
# real handler (Route Handler, Resend, Formspree, etc.).
# CONTACT_TO_EMAIL=hello@spacier.studio
# RESEND_API_KEY=
